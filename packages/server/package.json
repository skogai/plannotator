{
  "name": "@plannotator/server",
  "version": "0.19.24",
  "private": true,
  "description": "Shared server implementation for Plannotator plugins",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./review": "./review.ts",
    "./annotate": "./annotate.ts",
    "./remote": "./remote.ts",
    "./browser": "./browser.ts",
    "./goal-setup": "./goal-setup.ts",
    "./storage": "./storage.ts",
    "./git": "./git.ts",
    "./p4": "./p4.ts",
    "./vcs": "./vcs.ts",
    "./repo": "./repo.ts",
    "./share-url": "./share-url.ts",
    "./sessions": "./sessions.ts",
    "./project": "./project.ts",
    "./pr": "./pr.ts",
    "./daemon/client": "./daemon/client.ts",
    "./daemon/runtime": "./daemon/runtime.ts",
    "./daemon/session-factory": "./daemon/session-factory.ts",
    "./daemon/start-command": "./daemon/start-command.ts",
    "./daemon/state": "./daemon/state.ts"
  },
  "files": [
    "*.ts"
  ],
  "dependencies": {
    "@pierre/diffs": "^1.1.12",
    "@plannotator/shared": "workspace:*",
    "@plannotator/ai": "workspace:*"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  }
}
